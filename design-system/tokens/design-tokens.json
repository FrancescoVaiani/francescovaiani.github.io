{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "meta": {
    "name": "Signal Deck",
    "version": "1.1.0",
    "description": "Design token source for Francesco Vaiani personal site/CV",
    "themes": ["light", "dark"],
    "principles": [
      "Product-manager-first narrative",
      "Premium B2B clarity",
      "Desktop-first, mobile-safe",
      "Single source for screen and print"
    ]
  },
  "color": {
    "primitive": {
      "neutral": {
        "0": { "$type": "color", "$value": "#FCFDFE" },
        "50": { "$type": "color", "$value": "#F4F6F8" },
        "100": { "$type": "color", "$value": "#E9EDF2" },
        "200": { "$type": "color", "$value": "#D3DAE4" },
        "300": { "$type": "color", "$value": "#B4BFD0" },
        "400": { "$type": "color", "$value": "#8A97AD" },
        "500": { "$type": "color", "$value": "#627086" },
        "600": { "$type": "color", "$value": "#475266" },
        "700": { "$type": "color", "$value": "#2F3747" },
        "800": { "$type": "color", "$value": "#1D2432" },
        "900": { "$type": "color", "$value": "#111827" },
        "950": { "$type": "color", "$value": "#0A0F19" }
      },
      "accent": {
        "100": { "$type": "color", "$value": "#D9F2FF" },
        "200": { "$type": "color", "$value": "#B2E5FF" },
        "300": { "$type": "color", "$value": "#7CCFFF" },
        "400": { "$type": "color", "$value": "#3AB6FF" },
        "500": { "$type": "color", "$value": "#0098F0" },
        "600": { "$type": "color", "$value": "#0079C2" },
        "700": { "$type": "color", "$value": "#005E98" }
      },
      "status": {
        "success": { "$type": "color", "$value": "#0A8F5B" },
        "warning": { "$type": "color", "$value": "#B7791F" },
        "danger": { "$type": "color", "$value": "#C53030" }
      }
    },
    "semantic": {
      "background": {
        "canvas": { "$type": "color", "$value": "{color.primitive.neutral.0}" },
        "surface": { "$type": "color", "$value": "{color.primitive.neutral.50}" },
        "elevated": { "$type": "color", "$value": "#FFFFFF" },
        "inverse": { "$type": "color", "$value": "{color.primitive.neutral.950}" }
      },
      "text": {
        "strong": { "$type": "color", "$value": "{color.primitive.neutral.900}" },
        "default": { "$type": "color", "$value": "{color.primitive.neutral.700}" },
        "subtle": { "$type": "color", "$value": "{color.primitive.neutral.500}" },
        "inverse": { "$type": "color", "$value": "{color.primitive.neutral.0}" },
        "link": { "$type": "color", "$value": "{color.primitive.accent.600}" }
      },
      "interactive": {
        "primary": { "$type": "color", "$value": "{color.primitive.accent.500}" },
        "primaryHover": { "$type": "color", "$value": "{color.primitive.accent.600}" },
        "primaryActive": { "$type": "color", "$value": "{color.primitive.accent.700}" },
        "focusRing": { "$type": "color", "$value": "{color.primitive.accent.400}" }
      },
      "border": {
        "default": { "$type": "color", "$value": "{color.primitive.neutral.200}" },
        "strong": { "$type": "color", "$value": "{color.primitive.neutral.300}" },
        "accent": { "$type": "color", "$value": "{color.primitive.accent.500}" }
      }
    },
    "mode": {
      "light": {
        "background": {
          "canvas": { "$type": "color", "$value": "{color.semantic.background.canvas}" },
          "surface": { "$type": "color", "$value": "{color.semantic.background.surface}" },
          "elevated": { "$type": "color", "$value": "{color.semantic.background.elevated}" }
        },
        "text": {
          "strong": { "$type": "color", "$value": "{color.semantic.text.strong}" },
          "default": { "$type": "color", "$value": "{color.semantic.text.default}" },
          "subtle": { "$type": "color", "$value": "{color.semantic.text.subtle}" },
          "link": { "$type": "color", "$value": "{color.semantic.text.link}" }
        },
        "interactive": {
          "primary": { "$type": "color", "$value": "{color.semantic.interactive.primary}" },
          "primaryHover": { "$type": "color", "$value": "{color.semantic.interactive.primaryHover}" },
          "primaryActive": { "$type": "color", "$value": "{color.semantic.interactive.primaryActive}" }
        },
        "border": {
          "default": { "$type": "color", "$value": "{color.semantic.border.default}" },
          "strong": { "$type": "color", "$value": "{color.semantic.border.strong}" }
        }
      },
      "dark": {
        "background": {
          "canvas": { "$type": "color", "$value": "{color.primitive.neutral.950}" },
          "surface": { "$type": "color", "$value": "{color.primitive.neutral.900}" },
          "elevated": { "$type": "color", "$value": "{color.primitive.neutral.800}" }
        },
        "text": {
          "strong": { "$type": "color", "$value": "{color.primitive.neutral.50}" },
          "default": { "$type": "color", "$value": "{color.primitive.neutral.100}" },
          "subtle": { "$type": "color", "$value": "{color.primitive.neutral.300}" },
          "link": { "$type": "color", "$value": "{color.primitive.accent.300}" }
        },
        "interactive": {
          "primary": { "$type": "color", "$value": "{color.primitive.accent.400}" },
          "primaryHover": { "$type": "color", "$value": "{color.primitive.accent.300}" },
          "primaryActive": { "$type": "color", "$value": "{color.primitive.accent.500}" }
        },
        "border": {
          "default": { "$type": "color", "$value": "#223048" },
          "strong": { "$type": "color", "$value": "#31435F" }
        }
      }
    }
  },
  "font": {
    "family": {
      "heading": { "$type": "fontFamily", "$value": "Sora, Segoe UI, sans-serif" },
      "body": { "$type": "fontFamily", "$value": "Source Sans 3, Segoe UI, sans-serif" },
      "mono": { "$type": "fontFamily", "$value": "JetBrains Mono, Consolas, monospace" }
    },
    "size": {
      "caption": { "$type": "dimension", "$value": "0.875rem" },
      "body": { "$type": "dimension", "$value": "1rem" },
      "bodyLg": { "$type": "dimension", "$value": "1.125rem" },
      "h3": { "$type": "dimension", "$value": "1.25rem" },
      "h2": { "$type": "dimension", "$value": "1.75rem" },
      "h1": { "$type": "dimension", "$value": "2.75rem" },
      "display": { "$type": "dimension", "$value": "3.5rem" }
    },
    "weight": {
      "regular": { "$type": "fontWeight", "$value": "400" },
      "medium": { "$type": "fontWeight", "$value": "500" },
      "semibold": { "$type": "fontWeight", "$value": "600" },
      "bold": { "$type": "fontWeight", "$value": "700" }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.15 },
      "heading": { "$type": "number", "$value": 1.2 },
      "body": { "$type": "number", "$value": 1.55 },
      "relaxed": { "$type": "number", "$value": 1.7 }
    },
    "tracking": {
      "tight": { "$type": "dimension", "$value": "-0.02em" },
      "normal": { "$type": "dimension", "$value": "0em" },
      "wide": { "$type": "dimension", "$value": "0.03em" }
    }
  },
  "space": {
    "0": { "$type": "dimension", "$value": "0" },
    "1": { "$type": "dimension", "$value": "0.25rem" },
    "2": { "$type": "dimension", "$value": "0.5rem" },
    "3": { "$type": "dimension", "$value": "0.75rem" },
    "4": { "$type": "dimension", "$value": "1rem" },
    "5": { "$type": "dimension", "$value": "1.25rem" },
    "6": { "$type": "dimension", "$value": "1.5rem" },
    "8": { "$type": "dimension", "$value": "2rem" },
    "10": { "$type": "dimension", "$value": "2.5rem" },
    "12": { "$type": "dimension", "$value": "3rem" },
    "16": { "$type": "dimension", "$value": "4rem" }
  },
  "radius": {
    "sm": { "$type": "dimension", "$value": "0.375rem" },
    "md": { "$type": "dimension", "$value": "0.625rem" },
    "lg": { "$type": "dimension", "$value": "0.875rem" },
    "xl": { "$type": "dimension", "$value": "1.25rem" },
    "pill": { "$type": "dimension", "$value": "9999px" }
  },
  "shadow": {
    "soft": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(14, 30, 55, 0.08)",
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "0px"
      }
    },
    "raise": {
      "$type": "shadow",
      "$value": {
        "color": "rgba(14, 30, 55, 0.12)",
        "offsetX": "0px",
        "offsetY": "16px",
        "blur": "36px",
        "spread": "0px"
      }
    }
  },
  "motion": {
    "duration": {
      "fast": { "$type": "duration", "$value": "120ms" },
      "base": { "$type": "duration", "$value": "220ms" },
      "slow": { "$type": "duration", "$value": "420ms" }
    },
    "easing": {
      "standard": { "$type": "cubicBezier", "$value": [0.2, 0, 0, 1] },
      "emphasis": { "$type": "cubicBezier", "$value": [0.22, 1, 0.36, 1] }
    }
  },
  "layout": {
    "container": {
      "maxWidth": { "$type": "dimension", "$value": "73.75rem" },
      "paddingX": { "$type": "dimension", "$value": "1.5rem" }
    },
    "breakpoint": {
      "sm": { "$type": "dimension", "$value": "36rem" },
      "md": { "$type": "dimension", "$value": "48rem" },
      "lg": { "$type": "dimension", "$value": "64rem" },
      "xl": { "$type": "dimension", "$value": "80rem" }
    },
    "grid": {
      "desktopColumns": { "$type": "number", "$value": 12 },
      "tabletColumns": { "$type": "number", "$value": 8 },
      "mobileColumns": { "$type": "number", "$value": 4 },
      "gutter": { "$type": "dimension", "$value": "1.25rem" }
    }
  },
  "component": {
    "button": {
      "primary": {
        "background": { "$type": "color", "$value": "{color.semantic.interactive.primary}" },
        "backgroundHover": { "$type": "color", "$value": "{color.semantic.interactive.primaryHover}" },
        "text": { "$type": "color", "$value": "{color.semantic.text.inverse}" },
        "radius": { "$type": "dimension", "$value": "{radius.md}" },
        "paddingY": { "$type": "dimension", "$value": "{space.3}" },
        "paddingX": { "$type": "dimension", "$value": "{space.5}" }
      },
      "ghost": {
        "background": { "$type": "color", "$value": "transparent" },
        "text": { "$type": "color", "$value": "{color.semantic.text.strong}" },
        "border": { "$type": "color", "$value": "{color.semantic.border.default}" }
      }
    },
    "card": {
      "background": { "$type": "color", "$value": "{color.semantic.background.elevated}" },
      "border": { "$type": "color", "$value": "{color.semantic.border.default}" },
      "radius": { "$type": "dimension", "$value": "{radius.lg}" },
      "shadow": { "$type": "shadow", "$value": "{shadow.soft}" },
      "padding": { "$type": "dimension", "$value": "{space.6}" }
    },
    "timelineItem": {
      "rail": { "$type": "color", "$value": "{color.semantic.border.strong}" },
      "dot": { "$type": "color", "$value": "{color.semantic.interactive.primary}" }
    },
    "heroArt": {
      "backgroundStart": { "$type": "color", "$value": "#061126" },
      "backgroundEnd": { "$type": "color", "$value": "#0B1D3C" },
      "gridLine": { "$type": "color", "$value": "rgba(124, 207, 255, 0.24)" },
      "title": { "$type": "color", "$value": "#F8FBFF" },
      "body": { "$type": "color", "$value": "#D2DDED" },
      "shapeFill": { "$type": "color", "$value": "{color.semantic.background.surface}" },
      "shapeBorder": { "$type": "color", "$value": "{color.semantic.border.strong}" },
      "accentBar": { "$type": "color", "$value": "{color.semantic.interactive.primary}" },
      "frame": { "$type": "color", "$value": "rgba(106, 151, 206, 0.44)" },
      "radius": { "$type": "dimension", "$value": "{radius.xl}" }
    },
    "skillBar": {
      "track": { "$type": "color", "$value": "{color.semantic.border.default}" },
      "fill": { "$type": "color", "$value": "{color.semantic.interactive.primary}" },
      "height": { "$type": "dimension", "$value": "0.5rem" },
      "radius": { "$type": "dimension", "$value": "{radius.pill}" }
    }
  },
  "print": {
    "page": {
      "margin": { "$type": "dimension", "$value": "14mm" },
      "fontSize": { "$type": "dimension", "$value": "10.5pt" },
      "lineHeight": { "$type": "number", "$value": 1.35 }
    },
    "behavior": {
      "removeDecorativeUI": { "$type": "boolean", "$value": true },
      "singleColumn": { "$type": "boolean", "$value": true },
      "disableAnimation": { "$type": "boolean", "$value": true }
    }
  }
}
